# reCAPTCHA v3 Configuration
# Get these from: https://www.google.com/recaptcha/admin
# Create a new reCAPTCHA v3 key for the buildrex.ie domain
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key_here

# Resend Email API (Email Service)
# Get API key from: https://resend.com
RESEND_API_KEY=your_resend_api_key_here

# Email Configuration
# The email address that will receive contact form submissions
CONTACT_EMAIL=nathan@buildrex.ie
# The sender email address (should be your Resend verified domain)
EMAIL_USER=contact@buildrex.ie

# Optional: Contact Endpoint Override (for static hosting scenarios)
# NEXT_PUBLIC_CONTACT_ENDPOINT=/api/contact
